{
    "name": "SAM-6D Pose Estimation",
    "image": "lihualiu/sam-6d:1.0",

    "runArgs": [
        "--network=host",
        "--privileged",
        "--gpus=all",
        "--volume=/dev:/dev",
        "--volume=/dev/bus/usb:/dev/bus/usb",
        "--volume=/run/udev:/run/udev:ro",
        "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw",
        "--volume=${localEnv:HOME}/.Xauthority:/root/.Xauthority:rw",
        "--ipc=host"
    ],

    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}",
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "graphics,utility,compute,display",
        "QT_X11_NO_MITSHM": "1",
        "ROS_DOMAIN_ID": "0",
        "UR5E_ROBOT_IP": "192.168.8.4"
    },

    "containerUser": "root",
    "remoteUser": "root",

    // Keep the container running even if VS Code closes
    "shutdownAction": "stopContainer",

    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

    "customizations": {
        "vscode": {
           "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.vscode-pylance",
                "github.copilot",
                "github.copilot-chat",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "Ranch-Hand-Robotics.rde-ros-2"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },

    //Post create setup script
    "postCreateCommand": "bash /workspaces/${localWorkspaceFolderBasename}/.devcontainer/setup.sh"
}
